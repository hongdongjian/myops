{
  "theme": "tokyo-night",
  "display": {
    "padding": 1,
    "style": "powerline",
    "charset": "unicode",
    "theme": "tokyo-night",
    "colorCompatibility": "auto",
    "autoWrap": true,
    "lines": [
      {
        "segments": {
          "directory": {
            "enabled": true,
            "style": "full"
          },
          "model": {
            "enabled": true
          },
          "git": {
            "enabled": true,
            "showSha": false,
            "showWorkingTree": true,
            "showOperation": false,
            "showTag": false,
            "showTimeSinceCommit": false,
            "showStashCount": false,
            "showUpstream": false,
            "showRepoName": false
          },
          "metrics": {
            "enabled": true,
            "showResponseTime": false,
            "showLastResponseTime": true,
            "showDuration": false,
            "showMessageCount": false,
            "showLinesAdded": false,
            "showLinesRemoved": false
          },
          "context": {
            "enabled": true,
            "showPercentageOnly": false,
            "displayStyle": "blocks",
            "percentageMode": "used",
            "autocompactBuffer": "800000"
          },
          "tmux": {
            "enabled": false
          },
          "version": {
            "enabled": false
          },
          "session": {
            "enabled": false,
            "type": "tokens",
            "costSource": "calculated"
          },
          "block": {
            "enabled": false,
            "type": "weighted",
            "burnType": "cost"
          },
          "today": {
            "enabled": false,
            "type": "cost"
          }
        }
      }
    ]
  },
  "budget": {
    "session": {
      "warningThreshold": 80
    },
    "today": {
      "amount": 5.0,
      "warningThreshold": 80
    },
    "block": {
      "amount": 20000000,
      "type": "tokens",
      "warningThreshold": 80
    }
  },
  "modelContextLimits": {
    "sonnet": 200000,
    "default": 400000
  }
}
